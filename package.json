{
  "name": "mesh-editor",
  "version": "0.1.0",
  "description": "3D mesh viewer + parametric simplification (QEM / meshoptimizer) — Node.js web app inspired by 3daistudio.com",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,api -c cyan,magenta \"vite\" \"node --watch --max-old-space-size=4096 server/index.js\"",
    "build": "vite build",
    "start": "node --max-old-space-size=4096 server/index.js",
    "serve": "npm run build && npm run start"
  },
  "dependencies": {
    "@gltf-transform/core": "^4.1.1",
    "@gltf-transform/extensions": "^4.1.1",
    "@gltf-transform/functions": "^4.1.1",
    "draco3dgltf": "^1.5.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jszip": "^3.10.1",
    "meshoptimizer": "^0.22.0",
    "multer": "^2.2.0",
    "p-limit": "^6.2.0",
    "three": "^0.171.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "vite": "^6.0.7"
  }
}
